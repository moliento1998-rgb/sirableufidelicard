// ============================================================
// RÈGLES DE SÉCURITÉ FIRESTORE
// À coller dans Firebase Console → Firestore → Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Collection clients : lecture/écriture publique (le client s'inscrit sans auth)
    // Pour plus de sécurité, envisagez Firebase Auth Anonymous
    match /customers/{customerId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false; // Seul l'admin (via console ou Cloud Function) peut supprimer
    }

    // Notifications : lecture publique, écriture interdite côté client
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if false; // L'admin écrit via la page admin.html avec votre mot de passe
    }
  }
}

// NOTE : Pour une sécurité renforcée, utilisez Firebase Admin SDK
// avec une Cloud Function pour les opérations admin (ajout de points, notifications).
